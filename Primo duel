                                local p = math.clamp((tick() - start) / duration, 0, 1)
                                progressFill.Size = UDim2.new(p, 0, 1, 0)
                                percentLabel.Text = math.floor(p*100).."%"
                                if p >= 0.99 then
                                    pcall(function()
                                        fireproximityprompt(prompt, 10000)
                                        prompt:InputHoldBegin()
                                        task.wait(0.05)
                                        prompt:InputHoldEnd()
                                    end)
                                    start = tick()
                                end
                                task.wait()
                            end
                        end
                    end
                end
                resetBar()
                task.wait(0.15)
            end
            resetBar(true)
            hideSquare()
        end)
    end
end)

