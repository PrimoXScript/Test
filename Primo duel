            progressBarBg.Visible = true
            while autoStealEnabled do
                local char = lp.Character
                if char then
                    local root = char:FindFirstChild("HumanoidRootPart")
                    if root then
                        local prompt = nil
                        -- Simple nearest steal prompt logic
                        local plots = workspace:FindFirstChild("Plots")
                        if plots then
                            for _, plot in ipairs(plots:GetChildren()) do
                                for _, obj in ipairs(plot:GetDescendants()) do
                                    if obj:IsA("ProximityPrompt") and obj.Enabled and obj.ActionText == "Steal" then
                                        local pos = obj.Parent and obj.Parent.Position or nil
                                        if pos and (root.Position - pos).Magnitude <= grabRadius then
                                            prompt = obj
                                            break
                                        end
                                    end
                                end
                                if prompt then break end
                            end
                        end
                        if prompt then
                            local duration = 0.12
